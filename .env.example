# =============================================================================
# vnux-server-template — .env.example
# Copie para .env e preencha com seus valores reais
# NUNCA comite o .env no Git
# =============================================================================

# ─── Geral ───────────────────────────────────────────────────────────────────
# Fuso horário do servidor
TIMEZONE=America/Sao_Paulo

# ─── Domínio ─────────────────────────────────────────────────────────────────
# Domínio principal do site (sem https://)
DOMAIN=vnux.tech

# Aliases de domínio (subdomínios ou domínios adicionais)
DOMAIN_ALIASES=www.vnux.tech


# ─── Nginx ───────────────────────────────────────────────────────────────────
# Tamanho máximo de upload
CLIENT_MAX_BODY_SIZE=100M

# Worker processes (auto = número de CPUs)
WORKER_PROCESSES=auto

# ─── Cloudflare ──────────────────────────────────────────────────────────────
# Modo de proxy: true se usando Cloudflare Proxy (laranja)
CLOUDFLARE_PROXY=true

# ─── Backup ──────────────────────────────────────────────────────────────────
# Retenção de backups em dias
BACKUP_RETENTION_DAYS=30
